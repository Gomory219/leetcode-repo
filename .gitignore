# ========================== 1. Java 编译产物 ==========================
# 字节码文件（.class）
*.class
# Maven/Gradle 构建目录
target/
build/
# 临时编译文件
*.tmp
*.bak
# ========================== 2. VS Code 编辑器配置 ==========================
# VS Code 工作区配置（包含本地插件、设置等）
.vscode/
# VS Code 临时文件
*.code-workspace
# ========================== 3. 力扣刷题场景专属 ==========================
# 力扣本地调试的测试用例临时文件（比如自己写的 input.txt/output.txt）
*.txt
*.in
*.out
# 本地调试的日志文件
*.log
# ========================== 4. 通用无用文件 ==========================
# 操作系统临时文件
.DS_Store       # MacOS
Thumbs.db       # Windows
*.swp           # Linux 交换文件
# 压缩包/安装包
*.zip
*.rar
*.jar
# 环境变量/敏感配置（如果有本地配置文件）
.env
*.properties    # 非代码的配置文件（如果是业务配置可注释）
# IDE 通用缓存（防止误装其他 IDE 产生的文件）
.idea/
*.iml
.project
.classpath
.settings/